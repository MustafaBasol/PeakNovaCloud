generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Language {
  en
  tr
  fr
}

model About {
  id          String   @id @default(uuid())
  title       String
  description String
  language    Language
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([language])
}

model Faq {
  id        String   @id @default(uuid())
  question  String
  answer    String
  language  Language
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([language])
}

model Logos {
  id          String   @id @default(uuid())
  name        String
  description String
  language    Language
  icon        String
  color       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([language])
}

model Project {
  id          String   @id @default(uuid())
  name        String
  title       String?
  language    Language
  description String
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([language])
  @@index([createdAt])
}

model PageContent {
  id          String   @id @default(uuid())
  section     String
  title       String?
  description String?
  image       String?
  buttonText  String?
  language    Language
  cards       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([language, section])
}

model ServicePage {
  id          String   @id @default(uuid())
  service     String
  section     String
  title       String?
  description String?
  image       String?
  buttonText  String?
  language    Language
  cards       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([language])
  @@index([language, service, section])
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     Json
  coverImage  String?
  language    Language
  summary     String
  seo         Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([language])
  @@index([createdAt])
}

model Seo {
  id            String   @id @default(uuid())
  page          String
  language      Language
  title         String
  description   String
  keywords      String[]
  slug          String   @unique
  url           String?
  ogTitle       String?
  ogDescription String?
  ogImage       String?
  robots        String   @default("index, follow")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([language])
  @@index([language, page])
}