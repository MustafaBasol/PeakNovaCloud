{
  "name": "PeakNova",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:push:local": "DATABASE_URL='postgresql://postgres:postgres@localhost:5432/peaknova?schema=public' prisma db push",
    "prisma:generate:local": "DATABASE_URL='postgresql://postgres:postgres@localhost:5432/peaknova?schema=public' prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-form": "^0.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "cookie": "^1.0.2",
    "dotenv": "^16.4.5",
    "framer-motion": "^11.3.21",
    "html-react-parser": "^5.1.18",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.2.13",
    "next-intl": "^3.25.1",
    "nodemailer": "^6.9.14",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^5.2.1"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1"
  }
}
